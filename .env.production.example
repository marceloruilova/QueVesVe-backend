# Copiar como .env.production en el servidor y completar con valores reales

DJANGO_SECRET_KEY=genera-una-clave-secreta-larga-y-aleatoria
DJANGO_DEBUG=False
ALLOWED_HOSTS=api.quevesve.app

# PostgreSQL (Docker interno — no cambiar DATABASE_HOST)
DATABASE_NAME=quevesve_db
DATABASE_USER=quevesve_user
DATABASE_PASSWORD=password-seguro-aqui
DATABASE_HOST=db
DATABASE_PORT=5432

# Redis — cache compartido entre workers de Gunicorn, usado para contadores de
# rate limiting (DRF throttling). Sin esto los contadores serían por-proceso y el
# rate limiting sería inconsistente en producción. No cambiar el host (nombre del
# servicio en docker-compose.prod.yml).
REDIS_URL=redis://redis:6379/0

# URL pública del backend, usada para armar links (ej. verificación de email)
BACKEND_BASE_URL=https://api.quevesve.app

# Email (Gmail SMTP) — EMAIL_HOST_PASSWORD es un App Password de Gmail, no la contraseña normal
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST_USER=tu@gmail.com
EMAIL_HOST_PASSWORD=app-password-de-gmail

# CORS — orígenes web permitidos en producción (separados por coma)
CORS_ALLOWED_ORIGINS=https://quevesve.app

# Pexels (opcional, usado solo por el management command fetch_pexels)
PEXELS_API_KEY=

# Social auth — validación de audience de los tokens (ver Google Cloud Console / Facebook Developers)
# Client IDs propios de Google separados por coma (web, android, ios)
GOOGLE_OAUTH_CLIENT_IDS=
FACEBOOK_APP_ID=

# Cloudflare R2 (storage de video/thumbnails/fotos de perfil) — evita cargos de egress
# de DigitalOcean. Ver plan de migración para crear el bucket/API token/dominio custom.
# Dejar USE_R2_STORAGE=False hasta correr `migrate_media_to_r2` y verificar que los
# archivos migrados cargan bien desde R2_PUBLIC_DOMAIN.
USE_R2_STORAGE=False
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=quevesve-media
R2_ENDPOINT_URL=https://tu-account-id.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=cdn.quevesve.app

# Workaround de compatibilidad boto3/botocore >=1.36 con proveedores S3-compatible (R2 incluido)
AWS_REQUEST_CHECKSUM_CALCULATION=when_required
AWS_RESPONSE_CHECKSUM_VALIDATION=when_required

# Presupuesto de almacenamiento del catálogo propio (Pexels/Pixabay/Archive), en bytes.
# Usado por `cleanup_storage` para decidir cuándo purgar el contenido más viejo.
CATALOG_STORAGE_BUDGET_BYTES=5368709120
